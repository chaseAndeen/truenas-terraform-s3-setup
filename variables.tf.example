variable "aws_region" {
  description = "AWS region to deploy resources in"
  type        = string
  default     = "us-east-1"
}

variable "bucket_name" {
  description = "Globally unique S3 bucket name"
  type        = string
  default     = "my-nas-backups"
}

variable "iam_user_name" {
  description = "IAM user name for TrueNAS S3 sync"
  type        = string
  default     = "truenas-s3-sync-user"
}

variable "archive_days" {
  description = "Days before transitioning objects to S3 Glacier Deep Archive"
  type        = number
  default     = 1
}

variable "retention_days" {
  description = "Days to retain noncurrent object versions before deletion"
  type        = number
  default     = 180
}
